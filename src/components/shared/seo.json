{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "icon": "search",
    "description": "SEO metadata for pages and articles"
  },
  "options": {},
  "attributes": {
    "meta_title": {
      "type": "string",
      "maxLength": 70,
      "required": true
    },
    "meta_description": {
      "type": "text",
      "maxLength": 160,
      "required": true
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "canonical_url": {
      "type": "string"
    },
    "no_index": {
      "type": "boolean",
      "default": false
    }
  }
}
